APP_NAME="Koding Indonesia"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://kodingindonesia.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.kodingindonesia.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_SCHEME=ssl
MAIL_HOST=mail.kodingindonesia.com
MAIL_PORT=465
MAIL_USERNAME=noreply@kodingindonesia.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM_ADDRESS="noreply@kodingindonesia.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_CONTACT_EMAIL="anton.prafanto@gmail.com"

# Google Analytics 4 (optional)
# VITE_GA4_ID=G-XXXXXXXXXX

VITE_APP_NAME="${APP_NAME}"
