APP_NAME="Koding Indonesia"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://kodingindonesia.com

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_db_name
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.kodingindonesia.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file

MAIL_MAILER=smtp
MAIL_SCHEME=smtps
MAIL_HOST=your-cpanel-server.iixcp.rumahweb.net
MAIL_PORT=465
MAIL_USERNAME=your_email@kodingindonesia.com
MAIL_PASSWORD=your_mail_password
MAIL_FROM_ADDRESS="your_email@kodingindonesia.com"
MAIL_FROM_NAME="${APP_NAME}"
MAIL_CONTACT_EMAIL="your_inbox@example.com"

# Rumahweb: mirror uploads ke document root (sesuaikan path server)
PUBLIC_HTML_STORAGE=/home/CPANEL_USER/public_html/storage

# Seeder admin (hanya untuk setup awal — jangan commit nilai asli)
ADMIN_NAME="Admin"
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=generate-strong-password-here

# Masa berlaku link reset password (menit). Default 1440 = 24 jam.
AUTH_PASSWORD_RESET_EXPIRE=1440

# GitHub Actions deploy hook (generate: php -r "echo bin2hex(random_bytes(32));")
DEPLOY_HOOK_TOKEN=

# Google Analytics 4 (optional — aktif otomatis di production jika diisi)
GA4_MEASUREMENT_ID=

# Cloudflare Turnstile — anti-spam form kontak (https://dash.cloudflare.com → Turnstile)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

VITE_APP_NAME="${APP_NAME}"
